<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itheim.program_platform_backend.mapper.CategoryMapper">
    <select id="selectCategoriesByNames" resultType="com.itheim.program_platform_backend.domain.po.Category">
        SELECT id, name, create_time, update_time
        FROM category
        WHERE name IN
        <foreach collection="names" item="name" open="(" separator="," close=")">
            #{name}
        </foreach>
    </select></mapper>
